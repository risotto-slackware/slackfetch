#!/usr/bin/env bash
# slackfetch - Super-fast system info fetcher with DE, swap, battery, packages

# ------------------------------
# Colors
# ------------------------------
c1="\033[1;36m"
c2="\033[1;32m"
c0="\033[0m"

# ------------------------------
# Functions
# ------------------------------
get_os() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        echo "$NAME $VERSION"
    else
        uname -s
    fi
}

get_uptime() {
    if [ -r /proc/uptime ]; then
        local up=$(cut -d. -f1 /proc/uptime)
        local h=$((up/3600))
        local m=$(((up%3600)/60))
        echo "${h}h ${m}m"
    else
        echo "N/A"
    fi
}

get_cpu() {
    if [ -r /proc/cpuinfo ]; then
        grep -m1 "model name" /proc/cpuinfo | cut -d: -f2 | sed 's/^ //'
    else
        uname -p
    fi
}

get_mem() {
    if command -v free &>/dev/null; then
        free -h | awk '/Mem:/ {print $3 "/" $2}'
    else
        echo "N/A"
    fi
}

get_swap() {
    if command -v free &>/dev/null; then
        free -h | awk '/Swap:/ {print $3 "/" $2}'
    else
        echo "N/A"
    fi
}

get_disk() {
    df -h / | awk 'NR==2 {print $3 "/" $2 " (" $5 ")"}'
}

get_de() {
    if [ -n "$XDG_CURRENT_DESKTOP" ]; then
        echo "$XDG_CURRENT_DESKTOP"
    elif [ -n "$DESKTOP_SESSION" ]; then
        echo "$DESKTOP_SESSION"
    else
        echo "N/A"
    fi
}

get_battery() {
    for bat in /sys/class/power_supply/BAT*; do
        if [ -d "$bat" ]; then
            local cap=$(cat "$bat/capacity" 2>/dev/null)
            local status=$(cat "$bat/status" 2>/dev/null)
            echo "${cap}% (${status})"
            return
        fi
    done
    echo "N/A"
}

get_packages() {
    if [ -d /var/log/packages ]; then
        ls /var/log/packages | wc -l
    else
        echo "N/A"
    fi
}

# ------------------------------
# Gather system info
# ------------------------------
OS=$(get_os)
KERNEL=$(uname -r)
UPTIME=$(get_uptime)
SHELL=$(basename "$SHELL")
CPU=$(get_cpu)
RAM=$(get_mem)
SWAP=$(get_swap)
DISK=$(get_disk)
DE=$(get_de)
BATTERY=$(get_battery)
PACKAGES=$(get_packages)
USERHOST="$USER@$(hostname)"

# ------------------------------
# Output 
# ------------------------------
echo -e "${c1}   _____ _            _    ${c0}"
echo -e "${c1}  / ____| |          | |   ${c0} ${c2}$USERHOST${c0}"
echo -e "${c1} | (___ | | __ _  ___| | __${c0} ${c2}OS:${c0} $OS"
echo -e "${c1}  \\___ \\| |/ _\` |/ __| |/ /${c0} ${c2}Kernel:${c0} $KERNEL"
echo -e "${c1}  ____) | | (_| | (__|   < ${c0} ${c2}Uptime:${c0} $UPTIME"
echo -e "${c1} |_____/|_|\\__,_|\\___|_|\\_\\${c0} ${c2}Shell:${c0} $SHELL"
echo -e "                     ${c2}DE:${c0} $DE"
echo -e "                     ${c2}CPU:${c0} $CPU"
echo -e "                     ${c2}RAM:${c0} $RAM"
echo -e "                     ${c2}Swap:${c0} $SWAP"
echo -e "                     ${c2}Disk:${c0} $DISK"
echo -e "                     ${c2}Packages:${c0} $PACKAGES"
echo -e "                     ${c2}Battery:${c0} $BATTERY"
echo -e "                     ${c2}Swap:${c0} $SWAP"
echo -e "                     ${c2}Disk:${c0} $DISK"
